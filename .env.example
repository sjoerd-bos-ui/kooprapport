# Kopieer naar .env.local en vul in zodra een echte koppeling wordt geactiveerd.
# Ontbrekende MODE-vars vallen automatisch terug op "mock" — de app blijft
# altijd werken, ook zonder sleutels.

# BAG / Kadaster / PDOK
BAG_MODE=mock
BAG_API_BASE_URL=https://api.bag.kadaster.nl/lvbag/individuelebevragingen/v2
BAG_API_KEY=

# Energielabel — RVO / EP-Online (gratis, maar KvK-nummer verplicht bij
# aanvraag: https://apikey.ep-online.nl/), of overheid.io (derde partij,
# geen KvK nodig, betaald vanaf ca. €15/mnd: https://overheid.io/abonnementen)
ENERGIELABEL_MODE=mock
ENERGIELABEL_PROVIDER=ep-online
EP_ONLINE_API_BASE_URL=https://public.ep-online.nl/api/v5
EP_ONLINE_API_KEY=
# Alleen nodig als ENERGIELABEL_PROVIDER=overheid-io
OVERHEID_IO_API_BASE_URL=https://api.overheid.io/v3
OVERHEID_IO_API_KEY=

# Geschatte woningwaarde — Altum AI Woningwaarde+ API (avmplus). Geen officiële/
# gratis WOZ-API bestaat, dus dit is de gekozen bron voor "wat is deze woning
# waard": https://mopsus.altum.ai (account/sleutel aanmaken). Woningwaarde+
# i.p.v. de basis Woningwaarde API: niet NRVT-gebonden (claimen we toch niet),
# bredere dekking, en volgens Altum sneller/nauwkeuriger — zie de toelichting
# in lib/data-sources/woningwaarde.ts.
# ALTUM_SANDBOX=true test gratis tegen Altum's sandbox-endpoint (mock-output,
# geen credits, geen eigen sleutel nodig) — zet op false zodra je een eigen
# ALTUM_API_KEY hebt en echt wilt bevragen (kost credits per aanroep).
ALTUM_MODE=mock
ALTUM_SANDBOX=true
ALTUM_API_BASE_URL=https://api.altum.ai
ALTUM_API_KEY=

# Buurtverkopen — Altum AI Interactieve Woningreferentie API (bron: Kadaster).
# Gebruikt dezelfde ALTUM_API_KEY/ALTUM_SANDBOX hierboven, geen aparte sleutel.
BUURTVERKOPEN_MODE=mock

# Bestemming — twee losse sleutels (RP en DSO zijn technisch gescheiden
# systemen), maar ÉÉN gratis aanvraagformulier voor de PRODUCTIE-omgeving:
# https://developer.omgevingswet.overheid.nl/formulieren/api-key-dso-prod-omgeving-rp-aanvragen/
# (naam/e-mail/organisatie/telefoonnummer invullen, akkoord Fair Use Policy,
# bij "Ik ontvang graag een API-key voor" BEIDE vakjes aanvinken: "De diverse
# data en services van DSO" én "Ruimtelijke plannen" — dan komen beide
# sleutels uit dezelfde aanvraag). Zonder sleutel: mock-modus met bewust lege
# data (geen gegokte bestemming) — zie lib/data-sources/bestemming.ts.
#
# 1) Bestemmingsplan — Ruimtelijke Plannen API (Kadaster/Informatiehuis Ruimte),
#    dekt het "oude" systeem, wordt als eerste geprobeerd.
BESTEMMINGSPLAN_MODE=mock
RUIMTELIJKE_PLANNEN_API_BASE_URL=https://data.informatiehuisruimte.nl/api/ruimtelijke-plannen/v1
RUIMTELIJKE_PLANNEN_API_KEY=
# 2) Omgevingsplan — Omgevingsdocumenten-API's (DSO-LV), dekt het "nieuwe"
#    systeem sinds de Omgevingswet, alleen als fallback aangeroepen wanneer
#    bestemmingsplan niets vindt. Let op: de live-mapping hiervoor moet nog
#    geverifieerd worden (zie de stub-uitleg in bestemming.ts) — een sleutel
#    hier activeert dus nog geen werkende fallback.
OMGEVINGSPLAN_MODE=mock
OMGEVINGSDOCUMENTEN_API_BASE_URL=https://service.omgevingswet.overheid.nl
OMGEVINGSDOCUMENTEN_API_KEY=

# Betaling — Mollie (eenmalige iDEAL-betaling per rapport, https://mollie.com)
# PAYMENT_MODE=mock: bestellingen worden server-side meteen als "betaald"
# gemarkeerd, geen echte Mollie-aanroep, geen sleutel nodig.
# PAYMENT_MODE=live: vereist een MOLLIE_API_KEY (via my.mollie.com >
# Ontwikkelaars > API-sleutels — begin met een test-sleutel, "test_...").
# NEXT_PUBLIC_PAYMENT_MODE bepaalt alleen de tekst in PaywallModal, nooit of
# er daadwerkelijk ontgrendeld wordt (dat is altijd server-side, zie
# /api/rapport/premium) — hou 'm gelijk aan PAYMENT_MODE.
PAYMENT_MODE=mock
NEXT_PUBLIC_PAYMENT_MODE=mock
MOLLIE_API_KEY=
MOLLIE_API_BASE_URL=https://api.mollie.com/v2
# Moet in live-modus van buitenaf bereikbaar zijn (webhook) — geen localhost.
# Lokaal testen in live-modus: gebruik een tunnel (bv. `ngrok http 3000`).
APP_BASE_URL=http://localhost:3000

# Gedeelde key-value-store — gebruikt door lib/payments/bestellingen.ts
# (bestellingen/betaalstatus) én lib/services/rateLimit.ts. Zonder deze twee
# vars valt alles terug op een in-memory Map (prima voor lokaal ontwikkelen,
# NIET geschikt voor productie: gaat verloren bij herstart/nieuwe deploy en
# werkt niet met meerdere serverinstanties). Gratis Upstash Redis-database
# aanmaken op https://console.upstash.com, dan de REST-URL/-token hieronder
# overnemen. Vereist vóór je PAYMENT_MODE=live zet met echt geld.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Beveiligt /api/cron/reminder-email (verstuurt de "bewaar dit rapport"-
# herinnering, zie vercel.json) — Vercel voegt bij een geconfigureerde
# cronjob automatisch "Authorization: Bearer $CRON_SECRET" toe. Zonder deze
# var weigert dat endpoint elk verzoek. Verzin zelf een lange, willekeurige
# waarde (bv. `openssl rand -hex 32`).
CRON_SECRET=

# Zet en ondertekent de tijdelijke korting in de herinneringsmail (zie
# lib/utils/kortingToken.ts) — zonder deze var wordt er nooit een korting
# aangeboden (de mail gaat dan zonder kortingsblok). Verzin zelf een lange,
# willekeurige waarde (bv. `openssl rand -hex 32`), NIET hetzelfde als
# CRON_SECRET.
KORTING_SECRET=

# Beveiligt /api/admin/kortingscode -- de route waarmee je zelf, via curl in
# Terminal, handmatige kortingscodes aanmaakt ("WELKOM15" e.d.). Zonder deze
# var weigert die route alles. Andere waarde dan CRON_SECRET/KORTING_SECRET.
ADMIN_SECRET=
